<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Deployer.Gui"
             x:Class="Deployer.Gui.App">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme Mode="Light"/>
        <StyleInclude Source="avares://Deployer.Avalonia/UI/Styles/ModernTheme.axaml"/>
    </Application.Styles>
</Application>
